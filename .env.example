# Supabase — projeto dedicado à Folha (Settings > API), mesmo projeto usado pelo CRM (crm-folha)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# UazAPI — instância já conectada ao WhatsApp da Folha
UAZAPI_BASE_URL=https://sua-instancia-uazapi.com
UAZAPI_TOKEN=
# um ou mais números (formato sem 9º dígito, ex: 554187654321), separados por vírgula
UAZAPI_ADMIN_PHONE=
