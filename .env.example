# Supabase — projeto dedicado à Folha (Settings > API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Painel /leads — senha compartilhada da equipe + segredo p/ assinar o cookie de sessão
LEADS_PANEL_PASSWORD=
LEADS_SESSION_SECRET=

# Domínio dedicado ao CRM (ex: crm.folhaambiental.com.br). Configure o mesmo
# domínio no EasyPanel apontando pra este app. Sem essa env var, o CRM
# continua acessível em /leads no domínio da LP normalmente (dev/local).
CRM_DOMAIN=

# UazAPI — instância já conectada ao WhatsApp da Folha
UAZAPI_BASE_URL=https://sua-instancia-uazapi.com
UAZAPI_TOKEN=
# um ou mais números (formato sem 9º dígito, ex: 554187654321), separados por vírgula
UAZAPI_ADMIN_PHONE=
